# =====================================================
# VigilAgent Environment Variables
# =====================================================
# Copy this file to .env and fill in your values.
# Viper reads these with prefix VIGILAGENT_ and maps:
#   VIGILAGENT_DATABASE_HOST -> config.database.host
#   VIGILAGENT_REDIS_HOST    -> config.redis.host
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your values
#   go run ./cmd/api
#
# Or use Docker:
#   docker-compose -f docker-compose.dev.yml up -d
# =====================================================

# -- Server ----------------------------------------------------------
VIGILAGENT_SERVER_HOST=0.0.0.0
VIGILAGENT_SERVER_PORT=8080
# Options: development | production
VIGILAGENT_SERVER_ENV=development
VIGILAGENT_SERVER_READ_TIMEOUT=10s
VIGILAGENT_SERVER_WRITE_TIMEOUT=10s
VIGILAGENT_SERVER_IDLE_TIMEOUT=120s

# -- Database --------------------------------------------------------
# Option A: Local PostgreSQL (via docker-compose)
VIGILAGENT_DATABASE_HOST=localhost
VIGILAGENT_DATABASE_PORT=5432
VIGILAGENT_DATABASE_USER=vigilagent
VIGILAGENT_DATABASE_PASSWORD=vigilagent_dev
VIGILAGENT_DATABASE_NAME=vigilagent
VIGILAGENT_DATABASE_SSLMODE=disable
VIGILAGENT_DATABASE_MAX_OPEN_CONNS=25
VIGILAGENT_DATABASE_MAX_IDLE_CONNS=10
VIGILAGENT_DATABASE_MAX_LIFETIME=5m

# Option B: Supabase (uncomment below, comment Option A above)
# For Supabase pooler (IPv4 compatible), use session-mode port 5432
# For direct connection, use port 6543
# VIGILAGENT_DATABASE_HOST=aws-0-ap-northeast-1.pooler.supabase.com
# VIGILAGENT_DATABASE_PORT=5432
# VIGILAGENT_DATABASE_USER=postgres.YOUR_PROJECT_REF
# VIGILAGENT_DATABASE_PASSWORD=your-supabase-password
# VIGILAGENT_DATABASE_NAME=postgres
# VIGILAGENT_DATABASE_SSLMODE=require
# VIGILAGENT_DATABASE_MAX_OPEN_CONNS=15
# VIGILAGENT_DATABASE_MAX_IDLE_CONNS=5
# VIGILAGENT_DATABASE_MAX_LIFETIME=5m

# -- Redis -----------------------------------------------------------
# Used for: rate limiting, session caching, JWT blacklist, account lockout
VIGILAGENT_REDIS_HOST=localhost
VIGILAGENT_REDIS_PORT=6379
VIGILAGENT_REDIS_PASSWORD=
VIGILAGENT_REDIS_DB=0

# -- NATS JetStream --------------------------------------------------
# Used for: async task queue, webhook delivery
VIGILAGENT_NATS_URL=nats://localhost:4222
VIGILAGENT_NATS_STREAM=vigilagent

# -- Auth ------------------------------------------------------------
# JWT secret for signing tokens. In production, MUST be >= 32 chars
# and NOT the default value. Set via env var, not in this file.
VIGILAGENT_AUTH_JWT_SECRET=change-me-in-production
VIGILAGENT_AUTH_JWT_EXPIRATION=24h
# API key prefix (keys look like: va_abc123def456...)
VIGILAGENT_AUTH_API_KEY_PREFIX=va_

# -- Stripe (Billing) ------------------------------------------------
# Placeholder - not wired yet. Uncomment when integrating Stripe.
# VIGILAGENT_STRIPE_SECRET_KEY=sk_test_xxx
# VIGILAGENT_STRIPE_WEBHOOK_SECRET=whsec_xxx
# VIGILAGENT_STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
# VIGILAGENT_STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# -- Supabase (Auth) -------------------------------------------------
# Only needed if using Supabase Auth alongside local JWT
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# -- LLM Providers (for MCP server / background tasks) ---------------
# At least one provider key is needed for LLM-powered features.
# The MCP server accepts user-provided keys via X-LLM-Key header.
# OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# GEMINI_API_KEY=xxx

# -- Logging ---------------------------------------------------------
# Options: debug | info | warn | error
VIGILAGENT_LOG_LEVEL=info
# Options: json | text
VIGILAGENT_LOG_FORMAT=json

# -- CORS ------------------------------------------------------------
# Comma-separated list of allowed origins. Use * for development.
# VIGILAGENT_CORS_ALLOWED_ORIGINS=*
