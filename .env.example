# =====================================================
# VigilAgent Environment Variables
# =====================================================
# Copy this to .env and fill in your values
# Viper reads these with prefix VIGILAGENT_ and maps:
#   VIGILAGENT_DATABASE_HOST -> config.database.host
#   VIGILAGENT_REDIS_HOST    -> config.redis.host

# Server
VIGILAGENT_SERVER_HOST=0.0.0.0
VIGILAGENT_SERVER_PORT=8080
VIGILAGENT_SERVER_ENV=development
VIGILAGENT_SERVER_READ_TIMEOUT=10s
VIGILAGENT_SERVER_WRITE_TIMEOUT=10s
VIGILAGENT_SERVER_IDLE_TIMEOUT=120s

# =====================================================
# DATABASE - Local Development (default)
# =====================================================
VIGILAGENT_DATABASE_HOST=localhost
VIGILAGENT_DATABASE_PORT=5432
VIGILAGENT_DATABASE_USER=vigilagent
VIGILAGENT_DATABASE_PASSWORD=vigilagent_dev
VIGILAGENT_DATABASE_NAME=vigilagent
VIGILAGENT_DATABASE_SSLMODE=disable
VIGILAGENT_DATABASE_MAX_OPEN_CONNS=25
VIGILAGENT_DATABASE_MAX_IDLE_CONNS=10
VIGILAGENT_DATABASE_MAX_LIFETIME=5m

# =====================================================
# DATABASE - Supabase (uncomment below, comment local block above)
# =====================================================
# VIGILAGENT_DATABASE_HOST=db.YOUR-PROJECT-REF.supabase.co
# VIGILAGENT_DATABASE_PORT=5432
# VIGILAGENT_DATABASE_USER=postgres
# VIGILAGENT_DATABASE_PASSWORD=your-supabase-database-password
# VIGILAGENT_DATABASE_NAME=postgres
# VIGILAGENT_DATABASE_SSLMODE=require
# VIGILAGENT_DATABASE_MAX_OPEN_CONNS=25
# VIGILAGENT_DATABASE_MAX_IDLE_CONNS=10
# VIGILAGENT_DATABASE_MAX_LIFETIME=5m

# Redis
VIGILAGENT_REDIS_HOST=localhost
VIGILAGENT_REDIS_PORT=6379
VIGILAGENT_REDIS_PASSWORD=
VIGILAGENT_REDIS_DB=0

# NATS
VIGILAGENT_NATS_URL=nats://localhost:4222
VIGILAGENT_NATS_STREAM=vigilagent

# Auth
VIGILAGENT_AUTH_JWT_SECRET=change-me-in-production
VIGILAGENT_AUTH_JWT_EXPIRATION=24h
VIGILAGENT_AUTH_API_KEY_PREFIX=va_

# Stripe
VIGILAGENT_STRIPE_SECRET_KEY=sk_test_placeholder
VIGILAGENT_STRIPE_WEBHOOK_SECRET=whsec_placeholder
VIGILAGENT_STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
VIGILAGENT_STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# Logging
VIGILAGENT_LOG_LEVEL=info
VIGILAGENT_LOG_FORMAT=json
